# ─────────────────────────────────────────────────────────────
# WeXR AR Menu — environment
# Copy this file to `.env.local`. The app runs with NO config at all
# (defaults to the offline "local" backend). Set these only when you
# want real cross-device, multi-user orders via Supabase.
# ─────────────────────────────────────────────────────────────

# Backend driver: "local" (default, localStorage + live cross-tab sync)
# or "supabase" (real-time, cross-device, production).
NEXT_PUBLIC_BACKEND=local

# Required only when NEXT_PUBLIC_BACKEND=supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL — used to build absolute QR-code links to AR pages.
# In production set this to your deployed domain (e.g. https://menu.wexr.in).
# Leave blank to auto-detect from the browser.
NEXT_PUBLIC_SITE_URL=

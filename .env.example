# ─────────────────────────────────────────────────────────────
# WeXR AR Menu — environment
# Copy this file to `.env.local`. The app runs with NO config at all
# (defaults below let everything work immediately).
# ─────────────────────────────────────────────────────────────

# ── Restaurant panel login (handed over by WeXR) ──
# Server-only (NOT exposed to the browser). Change these per restaurant.
ADMIN_ID=admin
ADMIN_PASSWORD=wexr1234
# Secret used to sign the session cookie. Set a long random string in prod.
AUTH_SECRET=change-me-to-a-long-random-string

# ── Order backend ──
# "local"  = stored in the browser (single device/kiosk). Default, zero setup.
# "supabase" = shared database so orders from any phone reach the panel,
#              and revenue persists. (Recommended for a real handover.)
NEXT_PUBLIC_BACKEND=local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Public base URL — used to build absolute QR links to AR pages. ──
# In production set to your deployed domain (e.g. https://menu.wexr.in).
NEXT_PUBLIC_SITE_URL=
